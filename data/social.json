          "parameters":[
            { "id":"S2-SC-001","name":"Suppliers screened on social criteria",      "unit":"%","standards":["GRI 414-1","ESRS S2-1"],"capture":["ai_doc","erp"],"automation":"high","desc":"Supplier onboarding." },
            { "id":"S2-SC-002","name":"Suppliers audited (social)",                 "unit":"count","standards":["GRI 414-2","ESRS S2-3"],"capture":["ai_doc"],"automation":"high","desc":"Audit reports (SMETA etc.)." },
            { "id":"S2-SC-003","name":"Non-conformances identified",                "unit":"count","standards":["GRI 414-2"],"capture":["ai_doc"],"automation":"high","desc":"Audit findings." },
            { "id":"S2-SC-004","name":"Corrective actions closed",                  "unit":"%","standards":["ESRS S2-3"],"capture":["ai_doc","erp"],"automation":"medium","desc":"CAR system." },
            { "id":"S2-SC-005","name":"Spend in high-risk geographies",              "unit":"%","standards":["ESRS S2-4","TISC"],"capture":["erp"],"automation":"high","desc":"Geo + Maplecroft index." },
            { "id":"S2-SC-006","name":"Forced labour incidents identified",          "unit":"count","standards":["ESRS S2-4","GRI 409-1","UFLPA"],"capture":["ai_doc"],"automation":"medium","desc":"Adverse media + audit." },
            { "id":"S2-SC-007","name":"Child labour incidents identified",           "unit":"count","standards":["ESRS S2-4","GRI 408-1"],"capture":["ai_doc"],"automation":"medium","desc":"Audit + grievance." },
            { "id":"S2-SC-008","name":"Living wage in supply chain (% covered)",     "unit":"%","standards":["ESRS S2-4","WBA"],"capture":["ai_doc"],"automation":"low","desc":"Supplier survey." }
          ]
        },
        {
          "id":"S2-GR",
          "name":"Grievance & Remedy",
          "parameters":[
            { "id":"S2-GR-001","name":"Operational-level grievance mechanisms in place","unit":"y/n","standards":["UNGP 31","ESRS S2-3"],"capture":["ai_doc"],"automation":"high","desc":"Policy / hotline." },
            { "id":"S2-GR-002","name":"Grievances received (workforce + value chain)","unit":"count","standards":["ESRS S2-3"],"capture":["erp","ai_doc"],"automation":"high","desc":"Case mgmt." },
            { "id":"S2-GR-003","name":"Grievances closed / remediated",              "unit":"%","standards":["ESRS S2-3"],"capture":["erp"],"automation":"high","desc":"Closure tracking." }
          ]
