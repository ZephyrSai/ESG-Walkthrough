{
  "pillar": "Social",
  "code": "S",
  "summary": "Social parameters across own workforce, value-chain workers, affected communities, consumers/end-users — aligned with ESRS S1-S4, GRI 400 series, SASB, UNGPs, ILO Core Conventions.",
  "categories": [
    {
      "id": "S1",
      "name": "Own Workforce",
      "standard_anchor": "ESRS S1 · GRI 401-410 · ILO · UNGPs · SASB",
      "subcategories": [
        {
          "id": "S1-WC",
          "name": "Working Conditions",
          "parameters": [
            { "id":"S1-WC-001","name":"Total headcount (FTE)",                     "unit":"count","standards":["ESRS S1-6","GRI 2-7"],"capture":["erp"],"automation":"high","desc":"SAP HCM / Workday." },
            { "id":"S1-WC-002","name":"Headcount by gender / region / contract",  "unit":"count","standards":["ESRS S1-6","GRI 2-7"],"capture":["erp"],"automation":"high","desc":"HR master breakdown." },
            { "id":"S1-WC-003","name":"Non-employee workforce (contractors, agency)","unit":"count","standards":["ESRS S1-7"],"capture":["erp","ai_doc"],"automation":"high","desc":"Vendor invoices + master." },
            { "id":"S1-WC-004","name":"Coverage of collective bargaining agreements","unit":"%","standards":["ESRS S1-8","GRI 2-30"],"capture":["erp","ai_doc"],"automation":"high","desc":"HR + agreements." },
            { "id":"S1-WC-005","name":"Workers covered by social dialogue mechanisms","unit":"%","standards":["ESRS S1-8"],"capture":["erp"],"automation":"high","desc":"HR data." },
            { "id":"S1-WC-006","name":"Living wage gap (vs reference)",            "unit":"%","standards":["ESRS S1-10","WBA"],"capture":["erp","ai_doc"],"automation":"medium","desc":"Payroll vs Anker/WageIndicator." },
            { "id":"S1-WC-007","name":"Gender pay gap (mean & median)",            "unit":"%","standards":["ESRS S1-16","GRI 405-2"],"capture":["erp"],"automation":"high","desc":"Payroll analytics." },
            { "id":"S1-WC-008","name":"CEO pay ratio",                              "unit":"ratio","standards":["ESRS S1-16","SEC"],"capture":["erp","ai_doc"],"automation":"high","desc":"Payroll + proxy." },
            { "id":"S1-WC-009","name":"Working hours — average per worker",         "unit":"hrs","standards":["ILO C1"],"capture":["erp"],"automation":"high","desc":"Time & attendance." },
            { "id":"S1-WC-010","name":"Overtime hours",                              "unit":"hrs","standards":["ILO C1"],"capture":["erp"],"automation":"high","desc":"T&A overtime." }
          ]
        },
        {
          "id": "S1-EO",
          "name": "Equal Opportunity & Inclusion",
          "parameters": [
            { "id":"S1-EO-001","name":"% women in workforce",                       "unit":"%","standards":["ESRS S1-9","GRI 405-1"],"capture":["erp"],"automation":"high","desc":"HR." },
            { "id":"S1-EO-002","name":"% women in management",                      "unit":"%","standards":["ESRS S1-9","GRI 405-1","SASB"],"capture":["erp"],"automation":"high","desc":"Org chart levels." },
            { "id":"S1-EO-003","name":"% women on board",                            "unit":"%","standards":["ESRS S1-9","GRI 405-1","SEC"],"capture":["ai_doc"],"automation":"high","desc":"Proxy statement." },
            { "id":"S1-EO-004","name":"% under-represented minorities (region-specific)","unit":"%","standards":["ESRS S1-9","GRI 405-1"],"capture":["erp"],"automation":"high","desc":"Voluntary self-ID." },
            { "id":"S1-EO-005","name":"Workers with disabilities",                  "unit":"%","standards":["ESRS S1-12"],"capture":["erp","ai_doc"],"automation":"medium","desc":"Confidential disclosure." },
            { "id":"S1-EO-006","name":"Discrimination incidents (substantiated)",   "unit":"count","standards":["GRI 406-1","ESRS S1-17"],"capture":["ai_doc","erp"],"automation":"medium","desc":"HR case mgmt." },
            { "id":"S1-EO-007","name":"Pay equity adjustments made",                "unit":"$","standards":["ESRS S1-16"],"capture":["erp"],"automation":"high","desc":"Payroll adjustments." }
          ]
        },
        {
          "id": "S1-HS",
          "name": "Health & Safety",
          "parameters": [
            { "id":"S1-HS-001","name":"Fatalities (employee + contractor)",          "unit":"count","standards":["ESRS S1-14","GRI 403-9","SASB"],"capture":["scada","ai_doc","erp"],"automation":"high","desc":"Incident system + EHS." },
            { "id":"S1-HS-002","name":"Lost-time injury frequency rate (LTIFR)",     "unit":"/200k hrs","standards":["ESRS S1-14","GRI 403-9","OSHA"],"capture":["erp"],"automation":"high","desc":"EHS module." },
            { "id":"S1-HS-003","name":"Total recordable incident rate (TRIR)",      "unit":"/200k hrs","standards":["GRI 403-9","OSHA"],"capture":["erp"],"automation":"high","desc":"EHS module." },
            { "id":"S1-HS-004","name":"High-consequence work-related injuries",      "unit":"count","standards":["ESRS S1-14","GRI 403-9"],"capture":["erp","ai_doc"],"automation":"high","desc":"EHS." },
            { "id":"S1-HS-005","name":"Occupational illnesses",                      "unit":"count","standards":["ESRS S1-14","GRI 403-10"],"capture":["erp","ai_doc"],"automation":"high","desc":"Occ health records." },
            { "id":"S1-HS-006","name":"Near-miss reporting rate",                     "unit":"count","standards":["ESRS S1-14"],"capture":["erp","scada"],"automation":"high","desc":"Mobile reporting." },
            { "id":"S1-HS-007","name":"ISO 45001 certified sites",                   "unit":"count","standards":["ISO 45001"],"capture":["ai_doc"],"automation":"high","desc":"Certificate ingest." },
            { "id":"S1-HS-008","name":"Workers covered by H&S management system",   "unit":"%","standards":["GRI 403-8","ESRS S1-14"],"capture":["erp","ai_doc"],"automation":"high","desc":"HR + EHS coverage." },
            { "id":"S1-HS-009","name":"Process safety events (Tier 1, Tier 2)",     "unit":"count","standards":["API 754","SASB EM-EP-540a.1"],"capture":["scada","ai_doc"],"automation":"high","desc":"DCS alarms + incident classification." },
            { "id":"S1-HS-010","name":"H&S training hours",                          "unit":"hrs","standards":["ESRS S1-14","GRI 403-5"],"capture":["erp"],"automation":"high","desc":"LMS." }
          ]
        },
        {
          "id": "S1-TD",
          "name": "Training & Development",
          "parameters": [
            { "id":"S1-TD-001","name":"Avg training hours per employee",             "unit":"hrs","standards":["ESRS S1-13","GRI 404-1"],"capture":["erp"],"automation":"high","desc":"LMS." },
            { "id":"S1-TD-002","name":"Skills training spend",                       "unit":"$","standards":["ESRS S1-13"],"capture":["erp"],"automation":"high","desc":"GL." },
            { "id":"S1-TD-003","name":"% receiving regular performance reviews",     "unit":"%","standards":["GRI 404-3"],"capture":["erp"],"automation":"high","desc":"HR." }
          ]
        }
      ]
    },
    {
      "id": "S2",
