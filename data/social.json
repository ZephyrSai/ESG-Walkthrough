            { "id":"S4-P-001","name":"Product recalls",                              "unit":"count","standards":["GRI 416-2","SASB"],"capture":["erp","ai_doc"],"automation":"high","desc":"Recall log." },
            { "id":"S4-P-002","name":"Product safety incidents — serious injury",   "unit":"count","standards":["GRI 416-2","ESRS S4-3"],"capture":["ai_doc"],"automation":"medium","desc":"Customer complaints + reg." },
            { "id":"S4-P-003","name":"Non-compliance with product safety regs",     "unit":"count","standards":["GRI 416-2","ESRS S4-3"],"capture":["ai_doc","erp"],"automation":"high","desc":"Reg notices." },
            { "id":"S4-P-004","name":"Marketing & labelling non-compliance",        "unit":"count","standards":["GRI 417-2/417-3"],"capture":["ai_doc"],"automation":"medium","desc":"Regulator letters." },
            { "id":"S4-P-005","name":"Data breaches",                                "unit":"count","standards":["GRI 418-1","ESRS S4-3","GDPR"],"capture":["erp","ai_doc"],"automation":"high","desc":"InfoSec system + notifications." },
            { "id":"S4-P-006","name":"Customers affected by breaches",               "unit":"count","standards":["GRI 418-1","GDPR"],"capture":["erp","ai_doc"],"automation":"high","desc":"Breach reports." },
            { "id":"S4-P-007","name":"Accessibility — products meeting WCAG/EN 301 549","unit":"%","standards":["ESRS S4-4","EAA"],"capture":["ai_doc"],"automation":"medium","desc":"Conformance reports." },
            { "id":"S4-P-008","name":"Affordability programmes (low-income access)","unit":"qual","standards":["ESRS S4-4"],"capture":["ai_doc"],"automation":"low","desc":"Programme docs." }
