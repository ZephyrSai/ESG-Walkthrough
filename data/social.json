            { "id":"S3-C-002","name":"Operations with significant actual/potential impacts","unit":"count","standards":["GRI 413-2","ESRS S3-3"],"capture":["ai_doc"],"automation":"medium","desc":"ESIA." },
            { "id":"S3-C-003","name":"Indigenous Peoples — FPIC processes",         "unit":"count","standards":["IFC PS7","UNDRIP","GRI 411-1","ESRS S3-2"],"capture":["ai_doc"],"automation":"medium","desc":"FPIC records." },
            { "id":"S3-C-004","name":"Resettlement events",                          "unit":"count","standards":["IFC PS5","ESRS S3-4"],"capture":["ai_doc"],"automation":"medium","desc":"RAP records." },
            { "id":"S3-C-005","name":"Land disputes (active)",                       "unit":"count","standards":["ESRS S3-4"],"capture":["ai_doc"],"automation":"medium","desc":"Legal cases / NGO reports." },
            { "id":"S3-C-006","name":"Community investment ($)",                     "unit":"$","standards":["GRI 203-1","B4SI"],"capture":["erp"],"automation":"high","desc":"Donations + projects." },
            { "id":"S3-C-007","name":"Local procurement share",                      "unit":"%","standards":["GRI 204-1","ESRS S3-4"],"capture":["erp"],"automation":"high","desc":"Supplier geo." },
            { "id":"S3-C-008","name":"Local hiring share",                           "unit":"%","standards":["GRI 202-2","ESRS S3-4"],"capture":["erp"],"automation":"high","desc":"HR address vs site." },
            { "id":"S3-C-009","name":"Tax paid by jurisdiction (country-by-country)","unit":"$","standards":["GRI 207-4","BEPS CbCR","ESRS"],"capture":["erp"],"automation":"high","desc":"Statutory filings." }
