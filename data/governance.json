            { "id":"G5-AI-002","name":"High-risk AI systems inventory",                "unit":"count","standards":["EU AI Act"],"capture":["ai_doc","erp"],"automation":"medium","desc":"Inventory + classification." },
            { "id":"G5-AI-003","name":"AI conformity assessments completed",          "unit":"count","standards":["EU AI Act"],"capture":["ai_doc"],"automation":"medium","desc":"Audit records." },
            { "id":"G5-AI-004","name":"AI incidents reported",                         "unit":"count","standards":["EU AI Act"],"capture":["ai_doc","erp"],"automation":"high","desc":"Incident system." },
            { "id":"G5-AI-005","name":"ISO 42001 certified scope",                    "unit":"qual","standards":["ISO 42001"],"capture":["ai_doc"],"automation":"high","desc":"Certificate ingest." }
